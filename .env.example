# ---------------------------------------------------------------------------
# dual-pihole-control backend configuration
# Copy this file to ".env" and fill in real values. NEVER commit .env.
# ---------------------------------------------------------------------------

# Port the backend listens on (inside the container and published to host).
PORT=8088

# Shared secret the browser extension must send as:
#   Authorization: Bearer <CONTROL_TOKEN>
# Use a long random string. Example generator (PowerShell):
#   [Convert]::ToBase64String((1..32 | ForEach-Object {Get-Random -Max 256}))
CONTROL_TOKEN=change-this-long-random-token

# --- Pi-hole #1 -------------------------------------------------------------
PIHOLE_1_NAME=Primary
PIHOLE_1_BASE_URL=http://192.168.1.10
PIHOLE_1_PASSWORD=change-me
# Optional: API version per Pi-hole ("6" default, "5" supported as fallback).
PIHOLE_1_API_VERSION=6

# --- Pi-hole #2 -------------------------------------------------------------
PIHOLE_2_NAME=Secondary
PIHOLE_2_BASE_URL=http://192.168.1.11
PIHOLE_2_PASSWORD=change-me
PIHOLE_2_API_VERSION=6

# To add more Pi-holes later, keep numbering sequentially:
#   PIHOLE_3_NAME=...
#   PIHOLE_3_BASE_URL=...
#   PIHOLE_3_PASSWORD=...
#   PIHOLE_3_API_VERSION=6

# Default disable duration (seconds) when a request omits "seconds".
DEFAULT_DISABLE_SECONDS=300

# Comma-separated list of allowed CORS origins.
# Firefox extensions use moz-extension://<uuid> origins; the wildcard below
# allows any Firefox extension on the LAN. For Chrome later add chrome-extension://*
ALLOWED_ORIGINS=moz-extension://*
